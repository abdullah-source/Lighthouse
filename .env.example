# Copy this file to `.env` and fill in your API keys.
# `.env` is gitignored — never commit real keys.

# OpenAI API key — get one at https://platform.openai.com/api-keys
# Used to probe GPT-5 on behalf of the brand.
OPENAI_API_KEY=sk-...

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Used for query generation (Sonnet), probing (Sonnet), and parsing (Haiku).
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity (Sonar) API key — get one at https://www.perplexity.ai/settings/api
# Used to probe a RETRIEVAL-grounded engine so we capture the SOURCES the AI
# cites (the "why"). Pay-as-you-go, cents per query. Key starts with `pplx-`.
PERPLEXITY_API_KEY=pplx-...

# Optional: override the SQLite database file path.
# Defaults to ./data/probe.sqlite if unset.
# BRANDVIZ_DB_PATH=./data/probe.sqlite
